# ============================================================
# Polyglot Oracle — 环境变量配置模板
# 复制本文件为 .env 并填写你的 API Key
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM API（优先级：GLM > Coze > OpenAI > Mock降级）
# ------------------------------------------------------------

# 选项 A：智谱 GLM（推荐，国内访问稳定，OpenAI 兼容接口）
# 申请地址：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key_here
# 可选：覆盖默认模型（默认 glm-4-flash）
# OPENAI_STD_MODEL=glm-4-plus

# 选项 B：Coze
COZE_API_KEY=your_coze_api_key_here
COZE_BOT_ID=your_coze_bot_id_here
COZE_BASE_URL=https://api.coze.cn

# 选项 C：OpenAI 兼容接口（OpenAI / DeepSeek / 其他）
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# 向量数据库路径（绝对路径，留空则使用默认 ./data/vector_store）
# ------------------------------------------------------------
CHROMA_DB_PATH=
