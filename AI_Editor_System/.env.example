# ============================================================
# Polyglot Oracle — 环境变量配置模板
# 复制本文件为 .env 并填写你的 API Key
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM API（三选一，优先级：Coze > OpenAI > Mock降级）
# ------------------------------------------------------------

# 选项 A：Coze（推荐，国内访问稳定）
COZE_API_KEY=your_coze_api_key_here
COZE_BOT_ID=your_coze_bot_id_here
COZE_BASE_URL=https://api.coze.cn

# 选项 B：OpenAI 兼容接口（OpenAI / 智谱 / 其他）
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# 图像理解 VLM（ingest_engine Stage 2 使用）
# 用于 PDF 图片内容分析，不使用 ingest_engine 可留空
# ------------------------------------------------------------
ZHIPU_API_KEY=your_zhipu_api_key_here

# ------------------------------------------------------------
# 向量数据库路径（绝对路径，留空则使用默认 ./data/vector_store）
# ------------------------------------------------------------
CHROMA_DB_PATH=
